# ═══════════════════════════════════════════════════════════════
#  Frontend Environment Variables (.env)
#  Static HTML Application (No React)
#  ⚠️  SECURITY: Keep this file PRIVATE - NEVER commit to git
# ═══════════════════════════════════════════════════════════════

# ── ENVIRONMENT ──────────────────────────────────────
# development or production
APP_ENV=production

# ── API CONFIGURATION ────────────────────────────────
# Backend API Base URL - Points to Render deployment
APP_API_URL=https://roottolearn-api.onrender.com/api

# Local development (uncomment to use)
# APP_API_URL=http://localhost:4000/api

# ── PAYMENT GATEWAY (Public Keys Only) ───────────────
# Razorpay - INR payments (public key - safe for frontend)
APP_RAZORPAY_KEY=rzp_test_SYtDiHDucmTTq4

# Stripe - USD payments (optional, public key only)
# APP_STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxx

# ── FEATURE FLAGS ────────────────────────────────────
# Enable/disable features (true or false)
APP_ENABLE_AUDIO=true
APP_ENABLE_PAYMENTS=true
APP_ENABLE_ADS=true
APP_ENABLE_LOGIN=true
APP_ENABLE_SIGNUP=true

# ── ANALYTICS (Optional) ────────────────────────────
# Google Analytics ID (optional)
# APP_GA_ID=G-XXXXXXXXXX

# ── DEBUG MODE ──────────────────────────────────────
# Set to true to enable debug logging in console
APP_DEBUG=false

# ═══════════════════════════════════════════════════════════════
#  Notes:
#  - This file is loaded by config.js
#  - All variables are accessible via window.APP_CONFIG
#  - Only PUBLIC keys should be in frontend (no secrets!)
#  - For Netlify: add these vars in Site Settings
# ═══════════════════════════════════════════════════════════════
#  Security Reminders:
#  1. This file is loaded by config.js
#  2. ONLY public keys go here (no secret keys!)
#  3. For Netlify: add vars in Site Settings → Environment
#  4. All variables must reference window.APP_CONFIG in frontend
#  5. Do NOT commit .env to git - only .env.example
# ═══════════════════════════════════════════════════════════════
