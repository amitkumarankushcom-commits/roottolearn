# ============================================================
# FRONTEND ENVIRONMENT VARIABLES (.env.example)
# Copy this file to .env and fill in actual values
# NEVER commit .env to git - only .env.example
# ============================================================

# ── API CONFIGURATION ────────────────────────────────────
# Backend API URL - Change based on environment
REACT_APP_API_URL=http://localhost:4000/api

# Production Render deployment
# REACT_APP_API_URL=https://roottolearn-api.onrender.com/api

# ── ENVIRONMENT ──────────────────────────────────────────
REACT_APP_ENV=development

# Production
# REACT_APP_ENV=production

# ── PAYMENT KEYS (Public Keys Only - No Secret Keys!) ────

# Razorpay Public Key (frontend only)
REACT_APP_RAZORPAY_KEY=rzp_test_xxxxxxxxxxxxxxxx

# Stripe Public Key (frontend only)
# REACT_APP_STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxx

# ── GOOGLE ADS (Public Publisher ID only) ────────────────
# REACT_APP_GOOGLE_ADS_PUBLISHER_ID=ca-pub-xxxxxxxxxxxxxxxx

# ── ANALYTICS (optional) ─────────────────────────────────
# REACT_APP_GA_ID=G-XXXXXXXXXX

# ── FEATURE FLAGS (optional) ────────────────────────────
REACT_APP_ENABLE_AUDIO=true
REACT_APP_ENABLE_PAYMENTS=true
REACT_APP_ENABLE_ADS=true

# ============================================================
# IMPORTANT SECURITY NOTES:
# ============================================================
# 1. NEVER commit .env file to git - only .env.example
# 2. NEVER put secret keys in frontend - only public keys
# 3. For Netlify: add env vars in Site Settings → Build & Deploy
# 4. All frontend env vars must start with REACT_APP_
# 5. Restart dev server after changing .env: npm start
# ============================================================

# ── LOCAL DEVELOPMENT ────────────────────────────────────
# When developing locally, point to your local backend:
# REACT_APP_API_URL=http://localhost:4000/api

# ── PRODUCTION DEPLOYMENT ───────────────────────────────
# When deployed to Netlify, update API URL to your Render backend:
# REACT_APP_API_URL=https://yourdomain-api.onrender.com/api
