# ═══════════════════════════════════════════════════════════════
#  Backend Configuration for Render Deployment
#  Set these as environment variables in Render dashboard
# ═══════════════════════════════════════════════════════════════

# ── SERVER CONFIGURATION ──────────────────────────────────────────
NODE_ENV=production
# PORT is auto-assigned by Render, but set default
PORT=4000

# Frontend URL for CORS - Update with your Vercel domain
FRONTEND_URL=https://roottolearn.vercel.app

# CORS Origins - Allow both Vercel and custom domain
CORS_ORIGINS=https://roottolearn.vercel.app,https://www.roottolearn.com

# ── SUPABASE (PostgreSQL) - MANDATORY ─────────────────────────────
# Get DATABASE_URL from Supabase dashboard → Settings → Database
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_PUBLISHABLE_DEFAULT_KEY=YOUR_ANON_KEY

# ── AUTHENTICATION & SECURITY ────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=YOUR_JWT_SECRET_HERE
REFRESH_SECRET=YOUR_REFRESH_SECRET_HERE
JWT_EXPIRES_IN=15m
BCRYPT_ROUNDS=12

# ── EMAIL (Gmail SMTP) ───────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# ── OTP & SECURITY ───────────────────────────────────────────────
OTP_EXPIRY_MINUTES=15
OTP_MAX_ATTEMPTS=5
RATE_LIMIT_MAX=100

# ── AI SERVICES (Optional) ───────────────────────────────────────
OPENAI_API_KEY=YOUR_KEY_HERE
DEEPSEEK_API_KEY=YOUR_KEY_HERE
ANTHROPIC_API_KEY=YOUR_KEY_HERE

# ── PAYMENT GATEWAYS ─────────────────────────────────────────────
# Razorpay (INR - Primary)
RAZORPAY_KEY_ID=rzp_test_XXXXXX
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# Stripe (USD - Optional)
# STRIPE_SECRET_KEY=sk_test_XXXXXX
