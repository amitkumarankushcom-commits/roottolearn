# ── Server ──────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Database (pick ONE option) ────────────────────

# OPTION A: Supabase / PostgreSQL
# Project Settings → Database → Connection string → URI (Transaction pooler, port 6543)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# OPTION B: MySQL / phpMyAdmin
Leave DATABASE_URL blank and fill these instead:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=summariq_db

# ── JWT (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=15m
REFRESH_SECRET=replace_with_another_64_char_random
REFRESH_EXPIRES_IN=7d

# ── OTP ──────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ── Email (Gmail App Password) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16char_app_password
SMTP_FROM="RootToLearn <noreply@roottolearn.app>"

