# ============================================================
# BACKEND ENVIRONMENT VARIABLES (.env.example)
# Copy to .env and fill in actual values - NEVER commit .env to git
# ============================================================

# ── SERVER CONFIGURATION ─────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── DATABASE (Choose ONE option) ─────────────────────────
# Option A: Supabase (PostgreSQL) - RECOMMENDED
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Option B: Local MySQL (for development)
# Leave DATABASE_URL empty and uncomment below:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASS=
# DB_NAME=summariq_db

# ── AUTHENTICATION & SECURITY ────────────────────────────
JWT_SECRET=your-32-char-random-secret-key-here
REFRESH_SECRET=your-32-char-random-refresh-key-here
JWT_EXPIRES_IN=15m
BCRYPT_ROUNDS=12

# ── EMAIL (Gmail SMTP) ───────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-16-char-app-password
SMTP_FROM=your-email@gmail.com

# ── OTP SETTINGS ─────────────────────────────────────────
OTP_EXPIRY_MINUTES=15
OTP_MAX_ATTEMPTS=5

# ── PAYMENT INTEGRATION ──────────────────────────────────
# Razorpay (INR payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Stripe (USD payments - optional)
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# ── AI SERVICE KEYS ──────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=your-deepseek-api-key

# ── API RATE LIMITING ────────────────────────────────────
RATE_LIMIT_MAX=100

# ── SUPABASE KEYS (if using Supabase) ────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
# SUPABASE_SECRET_KEY=your-service-key

# ── GOOGLE ADS (optional) ────────────────────────────────
# GOOGLE_ADS_PUBLISHER_ID=ca-pub-xxxxxxxxxxxxxxxx
# GOOGLE_ADS_BANNER_UNIT=xxxxxxxxxxxxxxxx
# GOOGLE_ADS_INTERSTITIAL_UNIT=xxxxxxxxxxxxxxxx
# GOOGLE_ADS_RECTANGLE_UNIT=xxxxxxxxxxxxxxxx

# ============================================================
# SECURITY NOTES:
# 1. NEVER commit .env to git - only .env.example
# 2. Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. For production (Render), add via environment variables dashboard
# 4. Rotate keys periodically
# 5. Keep all secrets confidential
# ============================================================
