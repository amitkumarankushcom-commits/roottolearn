# ═══════════════════════════════════════════════════════════════
# NETLIFY PRODUCTION ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Frontend URLs (Update with your Netlify domain) ──────────────
FRONTEND_URL=https://your-site.netlify.app
BACKEND_URL=https://your-backend-api.netlify.app

# ── CORS Configuration ────────────────────────────────────────
# Allow requests from your Netlify domain
CORS_ORIGINS=https://your-site.netlify.app,https://www.your-domain.com

# ── Database: Supabase PostgreSQL (for production) ──────────────
# Use Supabase instead of local MySQL
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Or keep using MySQL if hosted externally:
# DB_HOST=your-mysql-host.com
# DB_PORT=3306
# DB_USER=your_db_user
# DB_PASS=your_db_password
# DB_NAME=your_db_name

# ── Supabase Configuration ────────────────────────────────────
SUPABASE_URL=https://[PROJECT-ID].supabase.co
SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_[YOUR_KEY]

# ── JWT Secrets (Generate new secure tokens) ────────────────────
# Generate these with: openssl rand -hex 64
JWT_SECRET=your_long_jwt_secret_here_minimum_64_characters
REFRESH_SECRET=your_long_refresh_secret_here_minimum_64_characters
JWT_EXPIRES_IN=15m

# ── Email Configuration (SendGrid recommended for production) ────
# Option 1: SendGrid (Recommended)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=SG.your_sendgrid_api_key_here
SMTP_FROM=noreply@your-domain.com

# Option 2: Gmail App Password
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your_gmail_app_password
# SMTP_FROM=your-email@gmail.com

# ── Bcrypt & Rate Limiting ────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=100

# ── OTP Configuration ────────────────────────────────────────
OTP_EXPIRY_MINUTES=15
OTP_MAX_ATTEMPTS=5

# ── AI APIs ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Payment Gateways ────────────────────────────────────────
# Stripe (if using in production)
# STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# Razorpay
RAZORPAY_KEY_ID=rzp_live_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Netlify Specific ────────────────────────────────────────
NETLIFY_SITE_ID=your_netlify_site_id
NETLIFY_API_KEY=your_netlify_personal_access_token

# ── Security ────────────────────────────────────────────────────
# Enable HTTPS only in production
SECURE_COOKIES=true
COOKIE_SECURE=true
COOKIE_HTTPONLY=true

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=info
